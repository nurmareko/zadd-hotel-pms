// Hotel PMS — MVP Prisma Schema (Solo dev, 2-month timeline)
// Drop into prisma/schema.prisma and run `npx prisma migrate dev --name init`
//
// Changes vs full design (24 tables → 17 tables):
// - Rate inlined into RoomType (one fixed base rate per type)
// - GuestRegistrationCard inlined into Reservation (grc_filled_at, purpose_of_visit)
// - Segment removed (no segment reporting)
// - MasterBill removed (no group billing)
// - ManualBill + ManualBillItem removed (walk-ins use Reservation.type = WALK_IN + Folio)
// - Outlet removed (single hardcoded outlet for F&B)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum RoomStatus {
  VC  // Vacant Clean
  VD  // Vacant Dirty
  OC  // Occupied Clean
  OD  // Occupied Dirty
  OOO // Out of Order
}

enum ArticleType {
  ROOM
  FB
  SERVICE
  TAX
  MISC
}

enum ReservationStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum ReservationType {
  REGULAR   // normal hotel guest
  WALK_IN   // ad-hoc non-staying guest (replaces ManualBill)
}

enum FolioStatus {
  OPEN
  CLOSED
  VOIDED
}

enum FBOrderStatus {
  OPEN       // captain order stage (being taken / in kitchen)
  BILLED     // customer has been presented the bill
  CLOSED     // paid
  VOIDED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHARGE_TO_ROOM
}

enum NightAuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ============================================================
// AUTHENTICATION
// ============================================================

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  email        String?  @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles                UserRole[]
  reservationsCreated  Reservation[]     @relation("ReservationCreator")
  folioLineItemsPosted FolioLineItem[]
  fbOrdersWaited       FBOrder[]
  housekeepingLogs     HousekeepingLog[]
  nightAuditsRun       NightAudit[]
  paymentsReceived     Payment[]

  @@map("user")
}

model Role {
  id          Int    @id @default(autoincrement())
  code        String @unique @db.VarChar(20) // FO, HK, FB, ACC, ADMIN
  name        String @db.VarChar(50)
  permissions Json

  users UserRole[]

  @@map("role")
}

model UserRole {
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

// ============================================================
// MASTER DATA
// ============================================================

model RoomType {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(20)
  name        String  @db.VarChar(50)
  description String? @db.Text
  capacity    Int
  baseRate    Decimal @map("base_rate") @db.Decimal(12, 2) // fixed, no seasonality

  rooms        Room[]
  reservations Reservation[]

  @@map("room_type")
}

model Room {
  id         Int        @id @default(autoincrement())
  number     String     @unique @db.VarChar(10)
  floor      Int
  roomTypeId Int        @map("room_type_id")
  status     RoomStatus @default(VC)

  roomType         RoomType          @relation(fields: [roomTypeId], references: [id])
  reservations     Reservation[]
  housekeepingLogs HousekeepingLog[]

  @@map("room")
}

model Article {
  id           Int         @id @default(autoincrement())
  code         String      @unique @db.VarChar(20)
  name         String      @db.VarChar(100)
  type         ArticleType
  defaultPrice Decimal?    @map("default_price") @db.Decimal(12, 2)

  folioLineItems FolioLineItem[]

  @@map("article")
}

model HotelSettings {
  id                   Int     @id @default(1)
  hotelName            String  @map("hotel_name") @db.VarChar(100)
  address              String? @db.Text
  taxPercent           Decimal @map("tax_percent") @db.Decimal(5, 2)
  serviceChargePercent Decimal @map("service_charge_percent") @db.Decimal(5, 2)
  nightAuditTime       String  @map("night_audit_time") @db.VarChar(5)
  currency             String  @default("IDR") @db.VarChar(5)

  @@map("hotel_settings")
}

// ============================================================
// FRONT OFFICE
// ============================================================

model Guest {
  id          Int       @id @default(autoincrement())
  fullName    String    @map("full_name") @db.VarChar(100)
  idNumber    String?   @map("id_number") @db.VarChar(50)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(100)
  address     String?   @db.Text
  nationality String?   @db.VarChar(50)
  birthDate   DateTime? @map("birth_date") @db.Date

  reservations Reservation[]

  @@map("guest")
}

model Reservation {
  id             Int               @id @default(autoincrement())
  reservationNo  String            @unique @map("reservation_no") @db.VarChar(20)
  type           ReservationType   @default(REGULAR)
  guestId        Int               @map("guest_id")
  roomTypeId     Int               @map("room_type_id")
  roomId         Int?              @map("room_id")
  arrivalDate    DateTime          @map("arrival_date") @db.Date
  departureDate  DateTime          @map("departure_date") @db.Date
  adults         Int               @default(1)
  children       Int               @default(0)
  status         ReservationStatus @default(CONFIRMED)
  rateAmount     Decimal           @map("rate_amount") @db.Decimal(12, 2) // snapshot of roomType.baseRate at booking time
  deposit        Decimal           @default(0) @db.Decimal(12, 2)
  notes          String?           @db.Text

  // GRC fields (inlined from GuestRegistrationCard entity)
  grcFilledAt    DateTime?         @map("grc_filled_at")
  purposeOfVisit String?           @map("purpose_of_visit") @db.VarChar(100)

  createdById    Int               @map("created_by_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  guest     Guest    @relation(fields: [guestId], references: [id])
  roomType  RoomType @relation(fields: [roomTypeId], references: [id])
  room      Room?    @relation(fields: [roomId], references: [id])
  createdBy User     @relation("ReservationCreator", fields: [createdById], references: [id])
  folio     Folio?

  @@map("reservation")
}

model Folio {
  id            Int         @id @default(autoincrement())
  folioNo       String      @unique @map("folio_no") @db.VarChar(20)
  reservationId Int         @unique @map("reservation_id")
  status        FolioStatus @default(OPEN)
  openedAt      DateTime    @default(now()) @map("opened_at")
  closedAt      DateTime?   @map("closed_at")

  reservation Reservation     @relation(fields: [reservationId], references: [id])
  lineItems   FolioLineItem[]
  payments    Payment[]
  fbOrders    FBOrder[]       @relation("ChargedFolio")

  @@map("folio")
}

model FolioLineItem {
  id          Int      @id @default(autoincrement())
  folioId     Int      @map("folio_id")
  articleId   Int      @map("article_id")
  fbOrderId   Int?     @map("fb_order_id")
  description String   @db.VarChar(255)
  quantity    Decimal  @default(1) @db.Decimal(8, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  postedById  Int      @map("posted_by_id")
  postedAt    DateTime @default(now()) @map("posted_at")

  folio    Folio    @relation(fields: [folioId], references: [id])
  article  Article  @relation(fields: [articleId], references: [id])
  fbOrder  FBOrder? @relation(fields: [fbOrderId], references: [id])
  postedBy User     @relation(fields: [postedById], references: [id])

  @@map("folio_line_item")
}

// ============================================================
// FOOD & BEVERAGE (single hardcoded outlet — "Hotel Restaurant")
// ============================================================

model MenuItem {
  id       Int     @id @default(autoincrement())
  code     String  @unique @db.VarChar(20)
  name     String  @db.VarChar(100)
  category String  @db.VarChar(50)
  price    Decimal @db.Decimal(12, 2)
  isActive Boolean @default(true) @map("is_active")

  orderItems FBOrderItem[]

  @@map("menu_item")
}

model FBOrder {
  id             Int            @id @default(autoincrement())
  orderNo        String         @unique @map("order_no") @db.VarChar(20)
  tableNo        String?        @map("table_no") @db.VarChar(10)
  status         FBOrderStatus  @default(OPEN)
  paymentMethod  PaymentMethod? @map("payment_method")
  chargedFolioId Int?           @map("charged_folio_id")
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  serviceCharge  Decimal        @default(0) @map("service_charge") @db.Decimal(12, 2)
  tax            Decimal        @default(0) @db.Decimal(12, 2)
  total          Decimal        @default(0) @db.Decimal(12, 2)
  waitedById     Int            @map("waited_by_id")
  openedAt       DateTime       @default(now()) @map("opened_at")
  closedAt       DateTime?      @map("closed_at")

  chargedFolio   Folio?          @relation("ChargedFolio", fields: [chargedFolioId], references: [id])
  waitedBy       User            @relation(fields: [waitedById], references: [id])
  items          FBOrderItem[]
  folioLineItems FolioLineItem[]
  payments       Payment[]

  @@map("fb_order")
}

model FBOrderItem {
  id         Int     @id @default(autoincrement())
  fbOrderId  Int     @map("fb_order_id")
  menuItemId Int     @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  amount     Decimal @db.Decimal(12, 2)
  notes      String? @db.VarChar(255)

  fbOrder  FBOrder  @relation(fields: [fbOrderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("fb_order_item")
}

// ============================================================
// HOUSEKEEPING
// ============================================================

model HousekeepingLog {
  id          Int        @id @default(autoincrement())
  roomId      Int        @map("room_id")
  oldStatus   RoomStatus @map("old_status")
  newStatus   RoomStatus @map("new_status")
  note        String?    @db.Text
  updatedById Int        @map("updated_by_id")
  updatedAt   DateTime   @default(now()) @map("updated_at")

  room      Room @relation(fields: [roomId], references: [id])
  updatedBy User @relation(fields: [updatedById], references: [id])

  @@map("housekeeping_log")
}

// ============================================================
// ACCOUNTING
// ============================================================

model NightAudit {
  id            Int              @id @default(autoincrement())
  businessDate  DateTime         @unique @map("business_date") @db.Date
  runById       Int              @map("run_by_id")
  runAt         DateTime         @default(now()) @map("run_at")
  status        NightAuditStatus
  totalRevenue  Decimal?         @map("total_revenue") @db.Decimal(14, 2)
  occupancyRate Decimal?         @map("occupancy_rate") @db.Decimal(5, 2)
  reportData    Json?            @map("report_data") // snapshot: revenue breakdown, guest list, transactions

  runBy User @relation(fields: [runById], references: [id])

  @@map("night_audit")
}

// ============================================================
// PAYMENT (polymorphic — exactly one of folioId / fbOrderId)
// ============================================================

model Payment {
  id           Int           @id @default(autoincrement())
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  reference    String?       @db.VarChar(100)
  folioId      Int?          @map("folio_id")
  fbOrderId    Int?          @map("fb_order_id")
  receivedById Int           @map("received_by_id")
  receivedAt   DateTime      @default(now()) @map("received_at")

  folio      Folio?   @relation(fields: [folioId], references: [id])
  fbOrder    FBOrder? @relation(fields: [fbOrderId], references: [id])
  receivedBy User     @relation(fields: [receivedById], references: [id])

  @@map("payment")
}
